POSTGRES_PASSWORD=admin123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:admin123@localhost:5432/boi_db

# MongoDB
MONGO_URL=mongodb://admin:admin123@localhost:27017/boi_mongodb?authSource=admin
