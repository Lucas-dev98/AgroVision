MINIO_PASSWORD=minioadmin
MINIO_BUCKET_IMAGES=boi-images
MINIO_BUCKET_VIDEOS=boi-videos

# FastAPI
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG
SECRET_KEY=your-secret-key-here-change-in-production

# Animal Service
ANIMAL_SERVICE_PORT=8001

# Weighing Service
WEIGHING_SERVICE_PORT=8002

# Health Service
